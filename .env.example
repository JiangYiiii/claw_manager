# OpenClaw Manager 环境变量配置

# ============ 版本管理 ============
VERSION=latest

# ============ Git 仓库配置 ============
# Traffic AI
TRAFFIC_AI_REPO=https://github.com/JiangYiiii/traffic-ai.git
TRAFFIC_AI_BRANCH=main

# Plugin Manager
PLUGIN_MANAGER_REPO=https://github.com/JiangYiiii/claw_plugin_manager.git
PLUGIN_MANAGER_BRANCH=main

# Credential Manager
CREDENTIAL_MANAGER_REPO=https://github.com/JiangYiiii/claw_credential_manager.git
CREDENTIAL_MANAGER_BRANCH=main

# ============ 服务端口 ============
TRAFFIC_AI_CONSOLE_PORT=3001
TRAFFIC_AI_ADMIN_PORT=3002
PLUGIN_MANAGER_PORT=8001
CREDENTIAL_MANAGER_PORT=8002
DASHBOARD_PORT=9000

# ============ OpenClaw 配置 ============
OPENCLAW_HOME=${HOME}/.openclaw

# ============ 安全凭证 ============
# 首次运行 ./scripts/init.sh 会自动生成
ADMIN_TOKEN=
CRED_TOKEN=

# ============ 构建参数 ============
# 是否使用构建缓存（加速构建）
DOCKER_BUILDKIT=1

# Git 凭证（私有仓库需要）
# 方式1: Personal Access Token
GIT_TOKEN=

# 方式2: SSH Key（推荐）
# 将 SSH key 放在 ~/.ssh/id_rsa，构建时会自动使用
